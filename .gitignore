# ============================================================
# Git 忽略文件配置
# 以下文件和目录不会被 Git 跟踪和提交
# ============================================================

# --- Python 虚拟环境 ---
venv/
rag_env/
env/
.venv/

# --- Python 缓存文件 ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# --- ChromaDB 向量库数据（含大量二进制文件，不适合提交） ---
chroma_db/

# --- Streamlit 配置（可能含密钥） ---
.streamlit/secrets.toml

# --- PyInstaller 打包产物 ---
dist/
build/
*.spec

# --- IDE 配置文件 ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- 操作系统文件 ---
.DS_Store
Thumbs.db

# --- 环境变量文件 ---
.env
.env.local
.env.*.local

# --- 临时文件 ---
*.tmp
*.log
~$*
temp/